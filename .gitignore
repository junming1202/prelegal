# =============================================================================
# Python / FastAPI
# =============================================================================

# Byte-compiled / optimised / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.env.bak

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# pytest / testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.cover

# mypy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# Ruff / linting caches
.ruff_cache/

# =============================================================================
# Environment & Secrets
# =============================================================================

.env
.env.*
!.env.example
*.pem
*.key
*.p12
secrets.json

# =============================================================================
